generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Turno {
  MANANA
  TARDE
  NOCHE
}

enum EstadoSlot {
  LIBRE
  RESERVADO
  BLOQUEADO
}

// Tabla técnica de infraestructura, no de dominio: existe porque Prisma
// se niega a generar un cliente o crear una migración con cero modelos
// definidos. /health no depende de esta tabla; usa SELECT 1.
model HealthCheck {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}

model Especialidad {
  id                    String   @id @default(uuid()) @db.Uuid
  nombre                String   @unique
  duracionCitaMinutos   Int
  medicos               Medico[]
}

model Medico {
  id                    String                 @id @default(uuid()) @db.Uuid
  nombre                String
  horasSemanales        Int
  especialidadId        String                 @db.Uuid
  especialidad          Especialidad           @relation(fields: [especialidadId], references: [id])
  programaciones        ProgramacionSemanal[]
}

model Consultorio {
  id                    String                 @id @default(uuid()) @db.Uuid
  codigo                String                 @unique
  nombre                String
  programaciones        ProgramacionSemanal[]
}

model ProgramacionSemanal {
  id                    String       @id @default(uuid()) @db.Uuid
  medicoId              String       @db.Uuid
  consultorioId         String       @db.Uuid
  diaSemana             Int
  turno                 Turno
  medico                Medico       @relation(fields: [medicoId], references: [id])
  consultorio           Consultorio  @relation(fields: [consultorioId], references: [id])
  slots                 Slot[]

  @@unique([medicoId, diaSemana, turno])
  @@unique([consultorioId, diaSemana, turno])
}

model Slot {
  id                    String               @id @default(uuid()) @db.Uuid
  programacionSemanalId String               @db.Uuid
  inicioUtc             DateTime             @db.Timestamptz(3)
  finUtc                DateTime             @db.Timestamptz(3)
  fechaLima             DateTime             @db.Date
  estado                EstadoSlot           @default(LIBRE)
  programacionSemanal   ProgramacionSemanal  @relation(fields: [programacionSemanalId], references: [id])

  @@unique([programacionSemanalId, inicioUtc])
  @@index([fechaLima, estado, inicioUtc])
}
