generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Tabla técnica de infraestructura, no de dominio: existe porque Prisma
// se niega a generar un cliente o crear una migración con cero modelos
// definidos. /health no depende de esta tabla; usa SELECT 1.
model HealthCheck {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}
